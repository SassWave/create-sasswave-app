{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "tarballDir": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "package.json",
          "package-lock.json"
        ],
        "message": "chore(release): ${nex tRelease.version} [skip ci]\n\n${nextRelease.notes}"
          }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": "🎉 **${nextRelease.name}** released!",
        "failComment": "❌ **Release failed:** [see CI logs](https://github.com/${options.repository}/actions)"
      }
    ]
  ]
}