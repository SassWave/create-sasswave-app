    "url": "https://github.com/SassWave/create-sasswave-app"
  },
  "bugs": {
    "url": "https://github.com/SassWave/create-sasswave-app/issues"
  },
  "homepage": "https://github.com/SassWave/create-sasswave-app#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "enquirer": "^2.4.1",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.2"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^11.0.0",
    "@semantic-release/commit-analyzer": "^11.0.0",
    "@semantic-release/release-notes-generator": "^12.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "semantic-release": "^24.2.3",
    "supertest": "^7.0.0"
  }
