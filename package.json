{
  "name": "create-sasswave",
  "version": "1.0.1",
  "description": "Zero-config CLI to scaffold SassWave-ready React or Next.js apps.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-sasswave": "bin/sasswave-create.js",
    "sasswave": "bin/sasswave-create.js"
  },
  "files": [
    "bin",
    "src",
    "assets-manifest.json",
    "docs",
    "README.md"
  ],
  "scripts": {
    "dev": "node bin/sasswave-create.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "release": "semantic-release"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "sasswave",
    "nextjs",
    "react",
    "vite",
    "cli",
    "scaffolding"
  ],
  "repository": {
